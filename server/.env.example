# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ──────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/recallai?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-hex-string
JWT_REFRESH_SECRET=replace-with-another-64-byte-hex-string

# ─── AES-256 Encryption (for user Gemini/OpenAI API keys) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=replace-with-32-byte-hex-string

# ─── Firebase Admin SDK ─────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON → copy values below

# Option A (recommended for production / Docker):
# Paste each field from the downloaded service account JSON:
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private_key value exactly, keep the \n escape sequences:
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"

# Option B (local dev only — path to downloaded service account JSON):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Frontend URL (CORS) ────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=debug
